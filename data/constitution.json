{
  "title": "League Constitution",
  "lastUpdated": "December 29, 2025",
  "sections": [
    {
      "heading": "Roster Positions",
      "rules": [
        "1 Quarterback (QB)",
        "2 Running Backs (RB)",
        "2 Wide Receivers (WR)",
        "1 Tight End (TE)",
        "3 FLEX (W/R/T)",
        "1 SUPERFLEX (Q/W/R/T)",
        "14 Bench spots",
        "1 IR slot"
      ]
    },
    {
      "heading": "Scoring — Passing",
      "rules": [
        "Passing yards: 1 point per 25 yards (0.04/yard)",
        "Passing TD: 4 points",
        "2-Pt Conversion: 2 points",
        "Interception: -1 point",
        "40+ Yard Completion Bonus: 1 point",
        "40+ Yard Pass TD Bonus: 1 point",
        "50+ Yard Pass TD Bonus: 2 points"
      ]
    },
    {
      "heading": "Scoring — Rushing",
      "rules": [
        "Rushing TD: 6 points",
        "2-Pt Conversion: 2 points",
        "40+ Yard Rush Bonus: 1 point",
        "40+ Yard Rush TD Bonus: 1 point",
        "50+ Yard Rush TD Bonus: 2 points"
      ]
    },
    {
      "heading": "Scoring — Receiving",
      "rules": [
        "Reception: 1 point (PPR)",
        "Receiving yards: 1 point per 10 yards (0.10/yard)",
        "Receiving TD: 6 points",
        "2-Pt Conversion: 2 points",
        "40+ Yard Reception Bonus: 1 point",
        "40+ Yard Reception TD Bonus: 1 point",
        "50+ Yard Reception TD Bonus: 2 points",
        "TE Reception Bonus: 0.5 points"
      ]
    },
    {
      "heading": "Scoring — Kicking",
      "rules": [
        "FG Made (0-19 yards): 3 points",
        "FG Made (20-29 yards): 3 points",
        "FG Made (30-39 yards): 3 points",
        "FG Made (40-49 yards): 4 points",
        "FG Made (50+ yards): 5 points",
        "PAT Made: 1 point",
        "FG Missed: -1 point"
      ]
    },
    {
      "heading": "Waivers & Free Agency",
      "rules": [
        "Waiver type: FAAB Bidding",
        "FAAB budget: $500 per season",
        "Minimum bid: $0",
        "Waivers clear: Tuesday (2 AM CDT) after games",
        "Players are on waivers for 1 day after being dropped",
        "Custom daily waivers enabled"
      ]
    },
    {
      "heading": "Trading",
      "rules": [
        "Time to review pending trades: 1 day",
        "Trade deadline: Week 12",
        "Draft pick trading is allowed"
      ]
    },
    {
      "heading": "Playoffs",
      "rules": [
        "Playoffs start: Week 15",
        "8 playoff teams",
        "One week per round",
        "Playoff seeding: Default (teams stay on initial side of bracket)",
        "Lower bracket: Toilet Bowl (losing team from each round gets flushed to the next round)"
      ]
    },
    {
      "heading": "Injured Reserve",
      "rules": [
        "IR slots: 1",
        "Suspended players allowed on IR"
      ]
    },
    {
      "heading": "Other Settings",
      "rules": [
        "Supplemental draft rounds: 3",
        "Bench players cannot be dropped after their game starts"
      ]
    },
    {
      "heading": "Dues & Payouts",
      "rules": [
        "Annual dues: $20 per team",
        "Dues must be paid before draft day — the draft will not start until everyone has paid"
      ]
    }
  ]
}
